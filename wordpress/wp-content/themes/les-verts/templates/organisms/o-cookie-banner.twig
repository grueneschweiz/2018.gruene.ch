<div class="o-cookie-banner" role="dialog" aria-labelledby="cookie-banner-text" aria-live="polite">
	<div class="o-cookie-banner__content">
		<p id="cookie-banner-text" class="o-cookie-banner__text">
			{{ cookie_banner.text|raw }}
			{% if cookie_banner.privacy_link %}
				<a href="{{ cookie_banner.privacy_link }}" class="o-cookie-banner__privacy-link" target="_blank" rel="noopener">
					{{ __('Datenschutzerklärung', constant('THEME_DOMAIN')) }}
				</a>
			{% endif %}
		</p>
		<div class="o-cookie-banner__actions">
			<button type="button" class="a-button o-cookie-banner__button o-cookie-banner__button--accept" data-action="accept">
				{{ __('Akzeptieren', constant('THEME_DOMAIN')) }}
			</button>
			<button type="button" class="a-button a-button--secondary o-cookie-banner__button o-cookie-banner__button--decline" data-action="decline">
				{{ __('Ablehnen', constant('THEME_DOMAIN')) }}
			</button>
		</div>
	</div>
	<button type="button" class="o-cookie-banner__close" aria-label="{{ __('Close banner', constant('THEME_DOMAIN')) }}" hidden>
		<svg role="img" aria-hidden="true">
			<title>{{ __('Close banner', constant('THEME_DOMAIN')) }}</title>
			<use xlink:href="#close"></use>
		</svg>
	</button>
</div>
